{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "rpi-image-gen capability registry",
  "description": "Capability token registry. Applied to the fully resolved registry after include processing.",
  "type": "object",
  "propertyNames": {
    "pattern": "^[a-z][a-z0-9]*(?::[a-z][a-z0-9-]*)+$"
  },
  "additionalProperties": {
    "type": "object",
    "required": ["desc"],
    "properties": {
      "desc": {
        "type": "string",
        "minLength": 1
      },
      "implies": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?::[a-z][a-z0-9-]*)+$"
        },
        "minItems": 1,
        "uniqueItems": true
      }
    },
    "additionalProperties": false
  }
}
